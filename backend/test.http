# ================================

# Health Check

# ================================

GET http://localhost:5000/api/health

###

# ================================

# Create Journal Entry

# ================================

POST http://localhost:5000/api/journal/
Content-Type: application/json

{
"user_id": "123",
"ambience": "nature",
"text": "I feel overwhelmed but hopeful about the future."
}

###

# ================================

# Create Another Journal Entry

# ================================

POST http://localhost:5000/api/journal/
Content-Type: application/json

{
"user_id": "123",
"ambience": "rain",
"text": "Listening to rain today helped me focus on my work."
}

###

# ================================

# Invalid Journal (Missing Field)

# ================================

POST http://localhost:5000/api/journal/
Content-Type: application/json

{
"user_id": "123",
"text": "This should fail because ambience is missing."
}

###

# ================================

# Fetch All Journals for User

# ================================

GET http://localhost:5000/api/journal/123

###

# ================================

# Fetch Journals for User With No Data

# ================================

GET http://localhost:5000/api/journal/999

###

# ================================

# Analyze Journal (First Time)

